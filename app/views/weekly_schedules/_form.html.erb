<%= form_with(model: weekly_schedule, class: "contents") do |form| %>
  <% if weekly_schedule.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(weekly_schedule.errors.count, "error") %> prohibited this weekly_schedule from being saved:</h2>

      <ul class="list-disc ml-6">
        <% weekly_schedule.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :day_of_week %>
    <%= form.number_field :day_of_week, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": weekly_schedule.errors[:day_of_week].none?, "border-red-400 focus:outline-red-600": weekly_schedule.errors[:day_of_week].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :start_time %>
    <%= form.text_field :start_time, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": weekly_schedule.errors[:start_time].none?, "border-red-400 focus:outline-red-600": weekly_schedule.errors[:start_time].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :max_capacity %>
    <%= form.number_field :max_capacity, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": weekly_schedule.errors[:max_capacity].none?, "border-red-400 focus:outline-red-600": weekly_schedule.errors[:max_capacity].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
