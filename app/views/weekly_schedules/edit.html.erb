<% content_for :title, "Editing weekly schedule" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-4xl">Editing weekly schedule</h1>

  <%= render "form", weekly_schedule: @weekly_schedule %>

  <%= link_to "Show this weekly schedule", @weekly_schedule, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= link_to "Back to weekly schedules", weekly_schedules_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
</div>
